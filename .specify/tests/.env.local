# Chromium nội bộ (Windows path — dùng cho executablePath trong playwright.config.ts)
# CHROMIUM_PATH=C:\Users\<you>\AppData\Local\pw-chromium\chrome-win\chrome.exe

# Browser hiển thị để debug nhanh trên máy dev
PW_HEADLESS=true

# Slow motion (ms) — giúp quan sát từng bước
# PW_SLOW_MO=100

# Chế độ ghi video: off | on | retain-on-failure | on-first-retry
PW_VIDEO=off