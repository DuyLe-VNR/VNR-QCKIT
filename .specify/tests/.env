# ============================================================
# ENV SELECTOR — chọn file .env.<ENV> sẽ được load tiếp theo
# Các giá trị hợp lệ: local | staging | prod
# ============================================================
ENV=local

# ============================================================
# CREDENTIALS — tài khoản đăng nhập mặc định (override trong .env.<ENV> nếu cần)
# ============================================================
# AUTH_USERNAME=username
# AUTH_PASSWORD=password


# ============================================================
# PLAYWRIGHT TUNING
# ============================================================
# Số worker chạy song song (overrides playwright.config.ts workers)
# PW_WORKERS=1

# Chạy ẩn browser (true) hay hiện browser (false)
# PW_HEADLESS=true

# Chế độ ghi video: off | on | retain-on-failure | on-first-retry
# PW_VIDEO=retain-on-failure

# Timeout mặc định cho từng action (ms)
# PW_ACTION_TIMEOUT=10000

# Timeout mặc định cho toàn bộ 1 test (ms)
# PW_TEST_TIMEOUT=60000

# ============================================================
# PATHS (hiếm khi cần đổi)
# ============================================================
# Thư mục lưu storage state sau khi login
# AUTH_STATE_PATH=./user.json

# Thư mục output report (để trống = tự sinh theo timestamp)
# REPORT_DIR=./test-results/latest
